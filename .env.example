# ─────────────────────────────────────────────────────────────
# ChatEdu Builder — Plantilla de variables de entorno (FRONTEND)
# ─────────────────────────────────────────────────────────────
# Cómo usar:
#   cp .env.example .env
#   Edita .env con los valores reales.
#
# NUNCA subas el archivo .env a un repositorio.
# Este archivo (.env.example) SÍ puede subirse — no contiene secretos.
# ─────────────────────────────────────────────────────────────

# ── URL base de la aplicación ─────────────────────────────────
# Usada para generar los enlaces del panel Deploy.
# Si se deja vacío, la app usa window.location.origin en runtime.
# Ejemplo producción: https://blue-moss-07818a11e7.azurestaticapps.net
VITE_APP_URL=

# ── Microsoft Entra ID (Paso 4) ───────────────────────────────
# Registro de aplicación en Azure Active Directory / Entra ID.
# Cómo obtenerlos:
#   1. Portal Azure → Azure Active Directory → Registros de aplicaciones
#   2. Crear o abrir el registro de la app
#   3. Página "Información general": copiar Application (client) ID y Directory (tenant) ID
#   4. Página "Autenticación": añadir URI de redirección (ej: http://localhost:5173)
#
# IMPORTANTE: Estos valores NO son secretos en el sentido de OAuth2.
# Son públicos por diseño (flujo PKCE). Pueden incluirse en el bundle.
# Añadirlos también a Application Settings de Azure Static Web Apps en producción.
#
# Si estas variables no están definidas, la app usa el modo stub demo (admin/admin).
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_REDIRECT_URI=http://localhost:5173

# ── Usuario de prueba admin/admin (solo modo demo) ────────────
# Solo activo cuando VITE_ENTRA_CLIENT_ID NO está definida (modo demo).
# true  → login con email "admin" y contraseña "admin" funciona sin BD.
# false → el bypass está desactivado.
# En producción con Entra ID, esta variable es ignorada completamente.
VITE_ENABLE_TEST_ADMIN=true
