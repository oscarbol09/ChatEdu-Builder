# ─────────────────────────────────────────────────────────────
# ChatEdu Builder — Variables de entorno (EJEMPLO)
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir el archivo .env a un repositorio.
# ─────────────────────────────────────────────────────────────

# API key de Google Gemini.
# Consíguela GRATIS (sin tarjeta de crédito) en:
# https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Azure Cosmos DB (opcional - si usás backend)
VITE_COSMOS_ENDPOINT=https://tu-cuenta.documents.azure.com:443/
VITE_COSMOS_KEY=tu-cosmos-key-aqui

# Azure Blob Storage (opcional)
VITE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=tu-cuenta;AccountKey=tu-key;EndpointSuffix=core.windows.net