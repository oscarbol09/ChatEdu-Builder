# ─────────────────────────────────────────────────────────────
# ChatEdu Builder — Plantilla de variables de entorno
# Copiar este archivo como .env y completar con los valores reales.
# NUNCA subir el archivo .env a un repositorio.
# ─────────────────────────────────────────────────────────────

# API key de Google Gemini.
# Consíguela GRATIS (sin tarjeta de crédito) en:
# https://aistudio.google.com/apikey
# El prefijo VITE_ es obligatorio para que Vite la exponga al cliente.
# ⚠️  SOLO para desarrollo local. En producción, mover a Azure Functions.
VITE_GEMINI_API_KEY=REEMPLAZAR_CON_TU_API_KEY_DE_GEMINI

# URL base de la aplicación desplegada.
# Se usa para generar los enlaces de despliegue de los chatbots en el Paso 4.
# Si no se define, la app detecta el dominio automáticamente con window.location.origin.
# Ejemplos:
#   Producción Azure:  https://blue-moss-07818a11e7.azurestaticapps.net
#   Dominio propio:    https://chatedu.tuuniversidad.edu.co
#   Desarrollo local:  dejar vacío (se usa localhost automáticamente)
VITE_APP_URL=

# Azure Cosmos DB
# Obtén el endpoint y la clave en Azure Portal → tu cuenta Cosmos DB → Claves
# ⚠️  SOLO para desarrollo local. En producción, usar Managed Identity + Key Vault.
VITE_COSMOS_ENDPOINT=https://TU_CUENTA.documents.azure.com:443/
VITE_COSMOS_KEY=TU_CLAVE_PRIMARIA_DE_COSMOS_DB

# Azure Blob Storage
# Obtén la connection string en Azure Portal → tu Storage Account → Claves de acceso
# ⚠️  SOLO para desarrollo local. En producción, usar Managed Identity + Key Vault.
VITE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=TU_CUENTA;AccountKey=TU_CLAVE;EndpointSuffix=core.windows.net
