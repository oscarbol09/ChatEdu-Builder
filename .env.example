# ─────────────────────────────────────────────────────────────
# ChatEdu Builder — Plantilla de variables de entorno (FRONTEND)
# ─────────────────────────────────────────────────────────────
# Cómo usar:
#   cp .env.example .env
#   Edita .env con los valores reales.
#
# NUNCA subas el archivo .env a un repositorio.
# Este archivo (.env.example) SÍ puede subirse — no contiene secretos.
# ─────────────────────────────────────────────────────────────

# ── URL base de la aplicación ─────────────────────────────────
# Usada para generar los enlaces del panel Deploy.
# Si se deja vacío, la app usa window.location.origin en runtime.
VITE_APP_URL=

# ── Microsoft Entra ID (Paso 4) ───────────────────────────────
# IMPORTANTE: Estas variables se configuran en GitHub Secrets.
# GitHub Actions las inyecta en tiempo de compilación (no en el portal de Azure).
#
# En GitHub → Settings → Secrets and variables → Actions → New repository secret:
#   VITE_ENTRA_CLIENT_ID   = ea8aee5a-c140-4748-81da-cac67b84f9ae
#   VITE_ENTRA_TENANT_ID   = 86f9e58e-33c2-4d36-b633-a65f2b3d012e
#   VITE_ENTRA_REDIRECT_URI = https://blue-moss-07818a11e.7.azurestaticapps.net
#   VITE_APP_URL           = https://blue-moss-07818a11e.7.azurestaticapps.net
#   VITE_GEMINI_API_KEY    = TU_API_KEY_DE_GEMINI
#
# Si no defined, la app usa el modo stub demo (admin/admin).
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_REDIRECT_URI=http://localhost:5173

# ── Usuario de prueba admin/admin (solo modo demo) ────────────
# Solo activo cuando VITE_ENTRA_CLIENT_ID NO está definida.
VITE_ENABLE_TEST_ADMIN=false
